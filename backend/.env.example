NODE_ENV=production
PORT=3001

# Vercel Postgres connection string (from Vercel dashboard)
DATABASE_URL=postgresql://user:pass@host/clinic_db?sslmode=require

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-256-bit-random-secret-here
JWT_EXPIRY=24h
BCRYPT_COST=12

# Your Vercel frontend URL
FRONTEND_ORIGIN=https://your-clinic.vercel.app

# SMS — set to false and add real MSG91 keys for production
SMS_MOCK=false
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=CLINIC
MSG91_WEBHOOK_SECRET=your-hmac-secret-from-msg91
MSG91_MISSED_CALL_VMN=+91XXXXXXXXXX

CANCELLATION_WINDOW_HOURS=2
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
ADMIN_ALERT_PHONE=+91XXXXXXXXXX
