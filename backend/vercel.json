{
  "version": 2,
  "builds": [{ "src": "api/index.ts", "use": "@vercel/node" }],
  "routes": [{ "src": "/(.*)", "dest": "api/index.ts" }],
  "crons": [
    { "path": "/api/jobs/send-reminders",     "schedule": "0 8 * * *" },
    { "path": "/api/jobs/expire-sessions",    "schedule": "0 9 * * *" },
    { "path": "/api/jobs/cleanup-rate-limits","schedule": "0 3 * * *" }
  ]
}
